# Example for Production Deployment (Linux / Docker)
# You can pass these via `docker-compose.yml` or set them directly in the environment.
# Note: In the Dockerfile, we have already set the default container paths for these variables.

APP_DATA_DIRECTORY=/app_data
TEMP_DIRECTORY=/tmp/presenton
USER_CONFIG_PATH=/app_data/user-config.json
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
NEXTJS_API_BASE_URL=http://127.0.0.1:3000
TEMPLATE_SOURCE=local
TEMPLATE_REMOTE_FALLBACK=false
TEMPLATE_CACHE_PRELOAD=true

# API Keys (set these in your server environment or docker-compose .env)
# OPENAI_API_KEY=your_key_here
# LLM=openai
