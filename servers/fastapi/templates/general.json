    {
      "id": "general:general-intro-slide",
      "name": "Intro Slide",
      "description": "A clean slide layout with title, description text, presenter info, and a supporting image.",
      "json_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "title": {
            "description": "Main title of the slide",
            "default": "Product Overview",
            "type": "string",
            "minLength": 3,
            "maxLength": 40
          },
          "description": {
            "description": "Main description text content",
            "default": "Our product offers customizable dashboards for real-time reporting and data-driven decisions. It integrates with third-party tools to enhance operations and scales with business growth for improved efficiency.",
            "type": "string",
            "minLength": 10,
            "maxLength": 150
          },
          "presenterName": {
            "description": "Name of the presenter",
            "default": "John Doe",
            "type": "string",
            "minLength": 2,
            "maxLength": 50
          },
          "presentationDate": {
            "description": "Date of the presentation must be the latest date like today's date",
            "default": "December 2025",
            "type": "string",
            "minLength": 2,
            "maxLength": 50
          },
          "image": {
            "description": "Supporting image for the slide",
            "default": {
              "__image_url__": "https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80",
              "__image_prompt__": "Business team in meeting room discussing product features and solutions"
            },
            "type": "object",
            "properties": {
              "__image_url__": {
                "description": "URL to image",
                "type": "string",
                "format": "uri"
              },
              "__image_prompt__": {
                "type": "string",
                "minLength": 10,
                "maxLength": 50
              }
            },
            "required": [
              "__image_url__",
              "__image_prompt__"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "title",
          "description",
          "presenterName",
          "presentationDate",
          "image"
        ],
        "additionalProperties": false
      }
    },
