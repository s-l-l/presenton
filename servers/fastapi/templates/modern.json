{
  "version": "v1",
  "name": "modern",
  "ordered": false,
  "slides": [
    {
      "id": "modern:intro-pitchdeck-slide",
      "name": "Intro Pitch Deck Slide",
      "description": "A visually appealing introduction slide for a pitch deck, featuring a large title, company name, date, and contact information with a modern design. This Slide is always the first slide in a pitch deck, setting the tone for the presentation with a clean and professional look.",
      "json_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "title": {
            "description": "Main title of the slide",
            "default": "Pitch Deck",
            "type": "string",
            "minLength": 2,
            "maxLength": 15
          },
          "description": {
            "description": "Description shown below the title",
            "default": "Add a short subtitle or description here. Add a short subtitle or description here. Add a short subtitle or description here. Add a short subtitle or description here.",
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "introCard": {
            "description": "Optional intro card shown below description",
            "default": {
              "enabled": true,
              "name": "John Doe",
              "date": "December 2025"
            },
            "type": "object",
            "properties": {
              "enabled": {
                "default": true,
                "type": "boolean"
              },
              "name": {
                "default": "John Doe",
                "type": "string",
                "minLength": 1,
                "maxLength": 60
              },
              "date": {
                "default": "December 2025",
                "type": "string",
                "minLength": 1,
                "maxLength": 60
              }
            },
            "required": [
              "enabled",
              "name",
              "date"
            ],
            "additionalProperties": false
          },
          "image": {
            "default": {
              "__image_url__": "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?q=80&w=1600&auto=format&fit=crop",
              "__image_prompt__": "Abstract business background"
            },
            "type": "object",
            "properties": {
              "__image_url__": {
                "description": "URL to image",
                "type": "string",
                "format": "uri"
              },
              "__image_prompt__": {
                "type": "string",
                "minLength": 10,
                "maxLength": 50
              }
            },
            "required": [
              "__image_url__",
              "__image_prompt__"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "title",
          "description",
          "introCard",
          "image"
        ],
        "additionalProperties": false
      }
    },
    {
