                "maxLength": 50
              }
            },
            "required": [
              "__image_url__",
              "__image_prompt__"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "title",
          "content",
          "image"
        ],
        "additionalProperties": false
      }
    },
